@startuml
class User
class Employee
class AuthController
class AuthService
class UserController
class UserService
class UserRepository
class EmployeeController
class EmployeeService
class EmployeeRepository

class AuthRequestDto
class AuthResponseDto
class CreateUserRequestDto
class EmployeeRequestForAdminDto
class EmployeeRequestForEmployeeDto
class EmployeeResponseForAdminDto
class EmployeeResponseForEmployeeDto
class ApiResponseDto<T>

enum Role
enum Department
enum Position
enum Status

class JwtProvider
class JwtFilter
class SecurityConfig
class AuthException
class ValidationException
class FileException
class GlobalExceptionHandler




' クラス定義
class User {
  - id: Long
  - email: String
  - password: String
  - role: Role

  + getId(): Long id
  + getEmail(): String email
  + getPassword(): String password
  + getRole(): Role role
  + setId(Long id)
  + setEmail(String email)
  + setPassword(String password)
  + setRole(Role role)
}

class Employee {
  - id: Long
  - employeeNumber: String
  - name: String
  - email: String
  - department: Department
  - position: Position
  - hireDate: LocalDate
  - status: Status

  + getId(): Long id
  + getEmployeeNumber(): String employeeNumber
  + getName(): String name
  + getEmail(): String email
  + getDepartment(): Department department
  + getPosition(): Position position
  + getHireDate(): LocalDate hireDate
  + getStatus(): Status status
  + setId(Long id)
  + setEmployeeNumber(String employeeNumber)
  + setName(String name)
  + setEmail(String email)
  + setDepartment(Department department)
  + setPosition(Position position)
  + setHireDate(LocalDate hireDate)
  + setStatus(Status status)
}

' 列挙型定義
enum Role {
  ADMIN
  EMPLOYEE
}

enum Department {
  GENERAL("総務"),
  HR("人事"),
  PLANNING("企画"),
  SALES("営業");
}

enum Position {
  STAFF("一般社員"),
  LEADER("主任"),
  MANAGER("課長"),
  DIRECTOR("部長"),
  EXECUTIVE("本部長"),
  CEO("社長");
}

enum Status {
  ACTIVE
  RETIRED
}

class AuthController {
  + login(AuthRequestDto req): ApiResponseDto<AuthResponseDto>
}

class AuthService {
  + authenticate(String email, String password): AuthResponseDto
}

class UserController {
  + createUser(CreateUserRequestDto req): ApiResponseDto<String>
}

class UserService {
  + save(CreateUserRequestDto req): String jwt-token
}

class UserRepository {
  + findByEmail(String email): User
}

class EmployeeController {
  + getEmployees(): ApiResponseDto<List<EmployeeResponseForAdminDto>> or ApiResponseDto<List<EmployeeResponseForEmployeeDto>>
  + getMe(): ApiResponseDto<EmployeeResponseForEmployeeDto>
  + createOrUpdateEmployee(EmployeeRequestForAdminDto req): ApiResponseDto<Void>
  + updateMe(EmployeeRequestForEmployeeDto req): ApiResponseDto<Void>
  + deleteEmployee(String employeeNumber): ApiResponseDto<Void>
  + importEmployees(MultipartFile file): ApiResponseDto<Void>
}

class EmployeeService {
  + findAll(): List<EmployeeResponseForAdminDto> or List<EmployeeResponseForEmployeeDto>
  + findMe(Long userId): EmployeeResponseForEmployeeDto
  + create(EmployeeRequestForAdminDto req): void
  + updateEmployee(String employeeNumber, EmployeeRequestForAdminDto req): void
  + updateMe(Long userId, EmployeeRequestForEmployeeDto req): void
  + deleteEmployee(String employeeNumber): void
  + importEmployees(MultipartFile file): void
}

class EmployeeRepository {
  + findByEmail(String email): Employee
  + findByEmployeeNumber(String employeeNumber): Employee
} 

' DTO
class AuthRequestDto {
  - email: String
  - password: String

  + getEmail()
  + getPassword()
}

class AuthResponseDto {
  - token: String

  + getToken()
  + setToken(String token)
}

class CreateUserRequestDto {
  - email: String
  - password: String
  - role: Role

  + getEmail()
  + getPassword()
  + getRole()
}

class EmployeeRequestForAdminDto {
  - employeeNumber: String
  - name: String
  - email: String
  - department: Department
  - position: Position
  - hireDate: LocalDate
  - status: Status

  + getEmployeeNumber()
  + getName()
  + getEmail()
  + getDepartment()
  + getPosition()
  + getHireDate()
  + getStatus()
}

class EmployeeResponseForAdminDto {
  - employeeNumber: String
  - name: String
  - email: String
  - department: Department
  - position: Position
  - hireDate: LocalDate
  - status: Status

  + getEmployeeNumber()
  + getName()
  + getEmail()
  + getDepartment()
  + getPosition()
  + getHireDate()
  + getStatus()
  + setEmployeeNumber(String employeeNumber)
  + setName(String name)
  + setEmail(String email)
  + setDepartment(Department department)
  + setPosition(Position position)
  + setHireDate(LocalDate hireDate)
  + setStatus(Status status)
}

class EmployeeRequestForEmployeeDto {
  - name: String
  - email: String

  + getName()
  + getEmail()
}

class EmployeeResponseForEmployeeDto {
  - name: String
  - email: String

  + getName()
  + getEmail()
  + setName(String name)
  + setEmail(String email)
}

class ApiResponseDto<T> {
  - status: String
  - data: T
  - message: String

  + getStatus()
  + getData()
  + getMessage()
  + setStatus(int status)
  + setData(T data)
  + setMessage(String message)
}

class JwtProvider {
  + generateToken(Long userId, Role role): String
  + validateToken(String token): boolean
  + getUserIdFromToken(String token): Long
}

class JwtFilter
class SecurityConfig
class AuthException
class ValidationException
class FileException
class GlobalExceptionHandler

@enduml